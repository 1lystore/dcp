{
  "name": "@dcprotocol/core",
  "version": "0.1.0",
  "description": "Core encryption, wallet, storage, and policy engine for DCP Vault",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1lystore/dcp.git",
    "directory": "packages/dcp-core"
  },
  "homepage": "https://github.com/1lystore/dcp#readme",
  "bugs": {
    "url": "https://github.com/1lystore/dcp/issues"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "vault",
    "encryption",
    "wallet",
    "solana",
    "crypto"
  ],
  "author": "DCP Protocol",
  "license": "Apache-2.0",
  "dependencies": {
    "@solana/web3.js": "^1.98.0",
    "better-sqlite3": "^11.7.0",
    "bip39": "^3.1.0",
    "bs58": "^6.0.0",
    "ethers": "^6.13.4",
    "keytar": "^7.9.0",
    "nanoid": "^5.0.9",
    "paseto": "^3.1.4",
    "sodium-native": "^4.3.1",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "vite": "^6.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/bip39": "^2.4.2",
    "@types/node": "^22.10.2",
    "@types/sodium-native": "^2.3.9",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
