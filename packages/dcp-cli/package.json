{
  "name": "@dcprotocol/cli",
  "version": "0.1.1",
  "description": "CLI for DCP Vault - manage wallets, data, and agent access",
  "type": "module",
  "main": "dist/cli.js",
  "types": "dist/cli.d.ts",
  "bin": {
    "dcp": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1lystore/dcp.git",
    "directory": "packages/dcp-cli"
  },
  "homepage": "https://github.com/1lystore/dcp#readme",
  "bugs": {
    "url": "https://github.com/1lystore/dcp/issues"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts --clean && chmod +x dist/cli.js",
    "dev": "npm run build -w @dcprotocol/core && npm run build && node dist/cli.js",
    "test": "npm run build && vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "vault",
    "cli",
    "wallet",
    "solana",
    "crypto"
  ],
  "author": "DCP Protocol",
  "license": "Apache-2.0",
  "dependencies": {
    "@dcprotocol/core": "^0.1.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^8.0.1",
    "prompts": "^2.4.2",
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "vite": "^6.0.0",
    "@types/node": "^22.10.2",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
